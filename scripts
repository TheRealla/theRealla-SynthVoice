class c:
    HEADER    = '\033[95m'
    OKBLUE    = '\033[94m'
    OKCYAN    = '\033[96m'
    OKGREEN   = '\033[92m'
    WARNING   = '\033[93m'
    FAIL      = '\033[91m'
    ENDC      = '\033[0m'
    BOLD      = '\033[1m'
    UNDERLINE = '\033[4m'

# ────────────────────────────────────────────────
#  Utility functions
# ────────────────────────────────────────────────

def run(cmd, cwd=None, check=True, capture_output=False):
    """Run a command and print it nicely"""
    print(f"  {c.OKCYAN}▶{c.ENDC}  {' '.join(str(arg) for arg in cmd)}")
    try:
        result = subprocess.run(
            cmd,
            cwd=cwd,
            check=check,
            text=True,
            capture_output=capture_output
        )
        if capture_output:
            return result.stdout.strip()
        return result
    except subprocess.CalledProcessError as e:
        print(f"\n{c.FAIL}Command failed with exit code {e.returncode}{c.ENDC}")
        print(e.stderr if e.stderr else "(no error output captured)")
        raise

def which(cmd):
    """Like unix 'which' – returns path if command exists in PATH"""
    try:
        return run(["which", cmd], capture_output=True, check=False) or None
    except:
        return None

