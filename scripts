#!/usr/bin/env python3
"""
build_synthvoice_all.py - Automate cmaj generate + JUCE/CMake build for SynthVoice plugin

Usage:
  python scripts/build_synthvoice_all.py [--juce-path /path/to/JUCE] [--output-dir Builds/JUCE_SynthVoice]
"""

import subprocess
import argparse
import os
import sys
import shutil

def run_command(cmd, cwd=None, check=True):
    """Run a shell command and print output."""
    print(f"Running: {' '.join(cmd)}")
    result = subprocess.run(cmd, cwd=cwd, check=check, capture_output=True, text=True)
    if result.stdout.strip():
        print(result.stdout)
    if result.stderr.strip():
        print("STDERR:", result.stderr, file=sys.stderr)
    return result

def main():
    parser = argparse.ArgumentParser(description="Build SynthVoice plugin from Cmajor patch")
    parser.add_argument("--juce-path", default=None, help="Path to local JUCE folder (optional)")
    parser.add_argument("--output-dir", default="Generated/JUCE_SynthVoice", help="Where to generate JUCE project")
    parser.add_argument("--build-type", default="Release", choices=["Debug", "Release"], help="CMake build type")
    parser.add_argument("--clean", action="store_true", help="Clean previous generated folder before generating")
    args = parser.parse_args()

    # Paths
    patch_file = "SynthVoice.cmajorpatch"
    if not os.path.exists(patch_file):
        sys.exit(f"Error: {patch_file} not found in current directory. Run from repo root.")

    output_dir = args.output_dir
    build_dir = os.path.join(output_dir, "build")

    # Optional: Clean previous generation
    if args.clean and os.path.exists(output_dir):
        print(f"Cleaning previous output: {output_dir}")
        shutil.rmtree(output_dir)

    # Step 1: Generate JUCE project from Cmajor patch
    cmaj_cmd = ["cmaj", "generate", "--target=juce", "--output", output_dir, patch_file]
    if args.juce_path:
        cmaj_cmd.extend(["--jucePath", args.juce_path])
    
    try:
        run_command(cmaj_cmd)
    except subprocess.CalledProcessError as e:
        sys.exit(f"cmaj generate failed with code {e.returncode}. Check cmaj CLI installation and patch syntax.")

    # Step 2: CMake configure
    cmake_configure = [
        "cmake", "-S", output_dir, "-B", build_dir,
        f"-DCMAKE_BUILD_TYPE={args.build_type}",
        "-DJUCE_BUILD_VST3=ON",
        "-DJUCE_BUILD_AU=ON",          # macOS only, ignored on Windows
        "-DJUCE_BUILD_CLAP=ON",
        "-DJUCE_BUILD_Standalone=ON",
    ]
    run_command(cmake_configure)

    # Step 3: Build
    cmake_build = [
        "cmake", "--build", build_dir,
        "--config", args.build_type,
        "--parallel",  # Use all cores
    ]
    run_command(cmake_build)

    print("\nBuild complete!")
    print(f"Plugins should be in: {os.path.join(build_dir, 'SynthVoice_artefacts')}")
    print(" - VST3: SynthVoice.vst3")
    print(" - AU (macOS): SynthVoice.component")
    print(" - CLAP: SynthVoice.clap")
    print(" - Standalone: SynthVoice.exe / SynthVoice.app")

if __name__ == "__main__":
    main()
